{
  "env": {
    "SHELL": "pwsh",
    "CLAUDE_SHELL": "pwsh",
    "CLAUDE_AGENTS_PATH": ".claude/agents",
    "PAGER": "less",
    "TERM": "xterm-256color",
    "DOTNET_CLI_TELEMETRY_OPTOUT": "1",
    "DOTNET_SKIP_FIRST_TIME_EXPERIENCE": "1",
    "NPM_CONFIG_LOGLEVEL": "warn",
    "NPM_CONFIG_COLOR": "always",
    "GIT_PAGER": "less",
    "GIT_ASKPASS": "echo",
    "AZURE_SUBSCRIPTION_ID": "${AZURE_SUBSCRIPTION_ID}",
    "AZURE_TENANT_ID": "${AZURE_TENANT_ID}",
    "AZURE_CLIENT_ID": "${AZURE_CLIENT_ID}",
    "AZURE_CLIENT_SECRET": "${AZURE_CLIENT_SECRET}",
    "OP_SERVICE_ACCOUNT_TOKEN": "${OP_SERVICE_ACCOUNT_TOKEN}",
    "PATH": "C:\\Program Files\\PowerShell\\7;C:\\Program Files\\dotnet;C:\\Program Files\\Microsoft SDKs\\Azure\\CLI2\\wbin\\;%LOCALAPPDATA%\\Microsoft\\WinGet\\Links\\"
  },
  "terminal": {
    "shell": "pwsh",
    "args": ["-ExecutionPolicy", "Bypass", "-Command"]
  },
  "permissions": {
    "allow": [
      "WebFetch(domain:docs.anthropic.com)",
      "Bash(winget:*)",
      "Bash(code:*)",
      "Bash(pwsh:*)",
      "Bash(mkdir:*)",
      "Bash(dotnet:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npm search:*)",
      "Bash(npx:*)",
      "Bash(git:*)",
      "Bash(prettier:*)",
      "Bash(markdownlint:*)",
      "Bash(op:*)",
      "Bash(az:*)"
    ],
    "deny": [],
    "ask": []
  },
  "hooks": {
    "bash": {
      "pre": [
        {
          "command": "pwsh -Command \"if (Get-Command refresh-env -ErrorAction SilentlyContinue) { refresh-env }\"",
          "condition": "command.startsWith('pwsh')"
        }
      ]
    }
  },
  "mcpServers": {
    "git": {
      "command": "pwsh",
      "args": ["-File", ".claude\\wrap-call.ps1", "npx", "-y", "@cyanheads/git-mcp-server"],
      "env": {
        "GIT_ALLOWED_REPOS": "C:\\Users\\bobby\\src"
      }
    },
    "nuget": {
      "command": "pwsh",
      "args": ["-File", ".claude\\wrap-call.ps1", "npx", "-y", "@microsoft/nuget-mcp-server"]
    },
    "filesystem": {
      "command": "pwsh",
      "args": ["-File", ".claude\\wrap-call.ps1", "npx", "-y", "@modelcontextprotocol/server-filesystem"],
      "env": {
        "ALLOWED_DIRECTORIES": "C:\\Users\\bobby\\src;C:\\Users\\bobby\\Documents;C:\\Users\\bobby\\Desktop"
      }
    },
    "context7": {
      "command": "pwsh",
      "args": ["-File", ".claude\\wrap-call.ps1", "npx", "-y", "@upstash/context7-mcp"]
    },
    "package-search": {
      "command": "pwsh",
      "args": ["-File", ".claude\\wrap-call.ps1", "npx", "-y", "@wong2/package-registry-search"]
    },
    "dotnet-cli": {
      "command": "pwsh",
      "args": ["-File", ".claude\\wrap-call.ps1", "npx", "-y", "@dotnet/mcp-dotnet-cli"]
    },
    "azure-devops": {
      "command": "pwsh",
      "args": ["-File", ".claude\\wrap-call.ps1", "npx", "-y", "@microsoft/azure-devops-mcp"]
    },
    "azure-cli": {
      "command": "pwsh",
      "args": ["-File", ".claude\\wrap-call.ps1", "npx", "-y", "@azure/mcp-server"]
    },
    "mssql": {
      "command": "pwsh",
      "args": ["-File", ".claude\\wrap-call.ps1", "npx", "-y", "@microsoft/mcp-server-mssql"]
    },
    "github": {
      "command": "pwsh",
      "args": ["-File", ".claude\\wrap-call.ps1", "npx", "-y", "@modelcontextprotocol/server-github"]
    },
    "windows-registry": {
      "command": "pwsh",
      "args": ["-File", ".claude\\wrap-call.ps1", "npx", "-y", "@microsoft/windows-registry-mcp"]
    }
  }
}
